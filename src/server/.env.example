# AI小组件云服务环境变量配置
# 复制此文件为 .env 并填入实际值

# ========================================
# AI 模型配置
# ========================================

# 阿里云通义千问（Qwen）API Key
# 获取方式：https://dashscope.console.aliyun.com/api-key
QWEN_API_KEY=your-qwen-api-key-here

# 模型选择（可选，默认为 qwen3.5-plus）
# 可选值：
#   - qwen-plus（推荐，中文质量高）
#   - qwen-turbo（速度更快）
#   - qwen-max（最强模型）
#   - qwen-turbo（经济型）
AI_MODEL=qwen-plus

# ========================================
# 其他 API（备用）
# ========================================

# OpenAI API Key（如需使用 GPT 模型）
OPENAI_API_KEY=

# Anthropic API Key（如需使用 Claude 模型）
ANTHROPIC_API_KEY=

# ========================================
# 服务配置
# ========================================

# 服务端口
PORT=8000

# Debug 模式
DEBUG=false

# 是否启用 Mock 模式（无 API Key 时自动启用）
USE_MOCK=false

# ========================================
# 新闻服务配置
# ========================================

# 新闻缓存 TTL（分钟），默认30
# NEWS_CACHE_TTL=30
